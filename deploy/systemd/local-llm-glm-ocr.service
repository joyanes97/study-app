[Unit]
Description=GLM-OCR llama.cpp server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/local-llm
EnvironmentFile=/home/local-llm/.config/glm-ocr/env
ExecStart=/bin/bash -lc '/home/local-llm/llama.cpp/build/bin/llama-server.real --model /home/local-llm/models/glm-ocr/GLM-OCR-Q8_0.gguf --mmproj /home/local-llm/models/glm-ocr/mmproj-GLM-OCR-Q8_0.gguf --host 0.0.0.0 --port 8081 --ctx-size 8192 --threads 8 --threads-batch 8 --parallel 1 --api-key "$GLM_OCR_API_KEY" --alias glm-ocr --no-webui'
Restart=always
RestartSec=10
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=full
ReadWritePaths=/home/local-llm
StandardOutput=append:/home/local-llm/glm-ocr.log
StandardError=append:/home/local-llm/glm-ocr.log

[Install]
WantedBy=default.target
