{
  "agents": {
    "defaults": {
      "workspace": "/home/jose/exam-study-app",
      "provider": "zhipu",
      "model": "glm-4.5"
    }
  },
  "providers": {
    "zhipu": {
      "apiKey": "${ZHIPU_API_KEY}",
      "apiBase": "https://open.bigmodel.cn/api/paas/v4"
    }
  },
  "gateway": {
    "port": 18791
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "TELEGRAM_BOT_TOKEN",
      "allowFrom": ["YOUR_TELEGRAM_USER_ID"]
    }
  },
  "tools": {
    "restrictToWorkspace": true,
    "exec": {
      "enable": true,
      "pathAppend": "/home/jose/exam-study-app/.venv/bin"
    }
  }
}
